# Root level gitignore to ignore build outputs, virtual environments, and node_modules

# Node.js dependencies and build output
client/node_modules/
client/dist/
client/dist-ssr/
client/.local

# Python virtual environment and caches
server/venv/
server/__pycache__/
server/**/*.pyc
server/.pytest_cache/

# OS specific files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
.env
.env.*
!.env.example
